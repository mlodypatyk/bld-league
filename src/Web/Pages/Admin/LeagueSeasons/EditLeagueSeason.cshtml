@page "/Admin/LeagueSeason/{id:guid}"
@model BldLeague.Web.Pages.Admin.LeagueSeasons.EditLeagueSeason

<div class="container mt-2">
    <h2>@Model.LeagueSeason.SeasonName - @Model.LeagueSeason.LeagueName</h2>
    <div class="mb-3">
        <label class="form-label">ID</label>
        <code class="d-block">@Model.Id</code>
    </div>

    <div class="d-flex gap-2 mb-3">
        <a asp-page-handler="ExportUsersCsv" class="btn btn-outline-secondary btn-sm">Export uczestników CSV</a>
        <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#importUsersForm">Import uczestników CSV</button>
    </div>

    <div class="collapse mb-3" id="importUsersForm">
        <div class="card card-body">
            <form method="post" asp-page-handler="ImportUsersCsv" enctype="multipart/form-data">
                <div class="mb-2">
                    <label class="form-label">Plik CSV (nagłówki: Season Number, League Identifier, WCA ID)</label>
                    <input type="file" name="file" accept=".csv" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-warning">Importuj</button>
            </form>
        </div>
    </div>

    @if (Model.ImportResult != null)
    {
        <div class="alert @(Model.ImportResult.HasErrors ? "alert-danger" : "alert-success") mb-3">
            <strong>@(Model.ImportResult.HasErrors ? "Import nieudany" : "Import zakończony pomyślnie")</strong>
            — @Model.ImportResult.SuccessCount sukcesów, @Model.ImportResult.ErrorCount błędów
        </div>
        <div class="table-responsive mb-3">
            <table class="table table-sm">
                <thead><tr><th>Wiersz</th><th>Status</th><th>Komunikat</th></tr></thead>
                <tbody>
                @foreach (var row in Model.ImportResult.RowResults)
                {
                    <tr class="@(row.Success ? "table-success" : "table-danger")">
                        <td>@row.RowNumber</td>
                        <td>@(row.Success ? "OK" : "Błąd")</td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <form method="post" asp-page-handler="SaveSettings" class="mb-4" style="max-width: 400px;">
        <h3>Ustawienia awansu / spadku</h3>
        <input type="hidden" asp-for="LeagueSeasonSettings.LeagueSeasonId" />
        <div class="mb-3">
            <label asp-for="LeagueSeasonSettings.PromotionCount" class="form-label">Liczba awansów</label>
            <input asp-for="LeagueSeasonSettings.PromotionCount" type="number" min="0" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="LeagueSeasonSettings.RelegationCount" class="form-label">Liczba spadków</label>
            <input asp-for="LeagueSeasonSettings.RelegationCount" type="number" min="0" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">Zapisz ustawienia</button>
    </form>

    <form id="saveGroupsForm" method="post" asp-page-handler="SaveGroups"></form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table">
            <tr>
                <th scope="col">Imię i nazwisko</th>
                <th scope="col">WCA ID</th>
                <th scope="col" class="text-center">Grupa</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @if (Model.AssignedUsers.Any())
            {
                var users = Model.AssignedUsers.ToList();
                for (var i = 0; i < users.Count; i++)
                {
                    var user = users[i];
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.WcaId</td>
                        <td class="text-center">
                            <input type="hidden" name="UserGroups[@i].UserId" value="@user.Id" form="saveGroupsForm" />
                            <input type="number" name="UserGroups[@i].SubleagueGroup" value="@user.SubleagueGroup" min="0" class="form-control form-control-sm mx-auto" style="width:5rem;" form="saveGroupsForm" />
                        </td>
                        <td>
                            <form method="post" asp-page-handler="RemoveUser"
                                  onsubmit="return confirm('Czy na pewno chcesz usunąć użytkownika z ligo-sezonu?\nJeżeli rozegrał już jakieś mecze, wszystkie wyniki zostaną skasowane.')">
                                <input type="hidden" name="RemoveUserId" value="@user.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="text-center">Nie znaleziono żadnego uczestnika.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    @if (Model.AssignedUsers.Any())
    {
        <button type="submit" form="saveGroupsForm" class="btn btn-primary mb-3">Zapisz grupy</button>
    }

    <h3>Dodaj uczestników</h3>
    <form method="post" asp-page-handler="AddUsers">
        <select id="selectedUsers" name="SelectedUserIds" multiple placeholder="Wyszukaj użytkowników…">
            @foreach (var user in Model.UnassignedUsers)
            {
                <option value="@user.Id">@user.FullName</option>
            }
        </select>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">Dodaj</button>
        </div>
    </form>
</div>

@section Styles {
    <!-- Page-specific CSS -->
    <link href="https://cdn.jsdelivr.net/npm/tom-select/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
}

@section Scripts {
    <!-- Page-specific JS -->
    <script src="https://cdn.jsdelivr.net/npm/tom-select/dist/js/tom-select.complete.min.js"></script>
    <script>
        new TomSelect("#selectedUsers", {
            plugins: ['remove_button'],
            maxItems: null,
            persist: false,
            create: false,
            closeAfterSelect: true,
            highlight: true,
        });
    </script>
}
