@page "/Admin/Rounds"
@using BldLeague.Application.Queries.Rounds.GetScrambles
@using BldLeague.Domain.Entities
@model BldLeague.Web.Pages.Admin.Rounds.AllRounds

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="mb-0">Lista kolejek</h2>
        <div class="d-flex gap-2">
            <a id="export-link" asp-page="/Admin/Rounds/AllRounds" asp-page-handler="ExportCsv"
               class="btn btn-outline-secondary">Export CSV</a>
            <button class="btn btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#importForm">Import CSV</button>
            <form method="post" asp-page-handler="RefreshAllStandings"
                  onsubmit="return confirm('Przelicz klasyfikacje wszystkich kolejek?')">
                <button type="submit" class="btn btn-success">Przelicz wszystkie kolejki</button>
            </form>
            <a asp-page="/Admin/Rounds/AddRound" class="btn btn-primary">Dodaj kolejkę</a>
        </div>
    </div>

    <div class="collapse mb-3" id="importForm">
        <div class="card card-body">
            <form method="post" asp-page-handler="ImportCsv" enctype="multipart/form-data">
                <div class="mb-2">
                    <label class="form-label">
                        Plik CSV (nagłówki: Season, Round, Start Date, End Date[, Scramble 1, …, Scramble @Match.SOLVES_PER_MATCH] — format dat: dd.MM.yyyy, scramble opcjonalne)
                    </label>
                    <input type="file" name="file" accept=".csv" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-warning">Importuj</button>
            </form>
        </div>
    </div>

    @if (Model.ImportResult != null)
    {
        <div class="alert @(Model.ImportResult.HasErrors ? "alert-danger" : "alert-success") mb-3">
            <strong>@(Model.ImportResult.HasErrors ? "Import nieudany" : "Import zakończony pomyślnie")</strong>
            — @Model.ImportResult.SuccessCount sukcesów, @Model.ImportResult.ErrorCount błędów
        </div>
        <div class="table-responsive mb-3">
            <table class="table table-sm">
                <thead><tr><th>Wiersz</th><th>Status</th><th>Komunikat</th></tr></thead>
                <tbody>
                @foreach (var row in Model.ImportResult.RowResults)
                {
                    <tr class="@(row.Success ? "table-success" : "table-danger")">
                        <td>@row.RowNumber</td>
                        <td>@(row.Success ? "OK" : "Błąd")</td>
                        <td>@row.Message</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }

    <div class="row g-2 align-items-end mb-3">
        <div class="col-auto">
            <label class="form-label mb-1">Sezon</label>
            <select id="filter-season" class="form-select form-select-sm">
                <option value="">Wszystkie</option>
            </select>
        </div>
        <div class="col-auto">
            <button id="filter-reset" type="button" class="btn btn-sm btn-outline-secondary">Resetuj</button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle js-table-pager">
            <thead class="table">
            <tr>
                <th scope="col">Sezon</th>
                <th scope="col">Kolejka</th>
                <th scope="col">Data rozpoczęcia</th>
                <th scope="col">Data zakończenia</th>
                @for (var i = 1; i <= Match.SOLVES_PER_MATCH; i++)
                {
                    <th scope="col" class="d-none d-lg-table-cell">Scramble @i</th>
                }
                <th scope="col">Akcje</th>
            </tr>
            </thead>
            <tbody id="rounds-body">
            @if (Model.Rounds.Any())
            {
                foreach (var round in Model.Rounds)
                {
                    var scrambles = Model.RoundScrambles.TryGetValue(round.Id, out var s) ? s : Array.Empty<ScrambleDto>();
                    <tr data-season="@round.SeasonNumber">
                        <td>@round.SeasonNumber</td>
                        <td>@round.RoundNumber</td>
                        <td>@round.StartDate.ToDisplayDate()</td>
                        <td>@round.EndDate.ToDisplayDate()</td>
                        @for (var i = 1; i <= Match.SOLVES_PER_MATCH; i++)
                        {
                            var notation = scrambles.FirstOrDefault(x => x.ScrambleNumber == i)?.Notation;
                            <td class="d-none d-lg-table-cell">
                                @if (!string.IsNullOrEmpty(notation))
                                {
                                    <span title="@notation" class="d-inline-block text-truncate" style="max-width: 100px;">@notation</span>
                                }
                            </td>
                        }
                        <td class="d-flex flex-wrap gap-1">
                            <a class="btn btn-sm btn-primary"
                               asp-page="/Admin/Rounds/EditRound"
                               asp-route-id="@round.Id">
                                Edytuj
                            </a>
                            @if (Model.IsRoundFinished(round.EndDate))
                            {
                                <form method="post" asp-page-handler="RefreshStandings">
                                    <input type="hidden" name="RefreshStandingsRoundId" value="@round.Id"/>
                                    <button type="submit" class="btn btn-sm btn-success">Przelicz klasyfikację</button>
                                </form>
                            }
                            <form method="post" asp-page-handler="RemoveRound"
                                  onsubmit="return confirm('Czy na pewno chcesz usunąć kolejkę?\nJeżeli rozegrano w niej mecze, wszystkie wyniki zostaną skasowane.')">
                                <input type="hidden" name="RemoveRoundId" value="@round.Id"/>
                                <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="@(4 + Match.SOLVES_PER_MATCH + 1)" class="text-center">Nie znaleziono żadnej kolejki.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<partial name="_TableSortPager" />

<script>
(function () {
    const rows = Array.from(document.querySelectorAll('#rounds-body tr[data-season]'));
    const selSeason = document.getElementById('filter-season');
    const resetBtn = document.getElementById('filter-reset');

    const seasons = [...new Set(rows.map(r => r.dataset.season))].sort((a, b) => b - a);
    seasons.forEach(v => {
        const o = document.createElement('option');
        o.value = v;
        o.textContent = v;
        selSeason.appendChild(o);
    });

    const table = document.querySelector('table.js-table-pager');

    function applyFilter() {
        const s = selSeason.value;
        rows.forEach(row => {
            const visible = !s || row.dataset.season === s;
            row.classList.toggle('filtered-out', !visible);
            row.style.display = visible ? '' : 'none';
        });
        table.dispatchEvent(new Event('tablefilter'));
    }

    selSeason.addEventListener('change', applyFilter);
    resetBtn.addEventListener('click', function () {
        selSeason.value = '';
        applyFilter();
    });
})();
</script>
