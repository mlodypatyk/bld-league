@page "/Statistics"
@using System.Globalization
@using System.Text.Json
@using BldLeague.Web.Helpers
@using BldLeague.Web.Pages.Statistics
@model BldLeague.Web.Pages.Statistics.Statistics

@{
    ViewData["Title"] = "Statystyki";
    var dayNames = Statistics.PolishDayNames();

    string Pct(int valid, int attempts) => attempts > 0
        ? $"{(100.0 * valid / attempts).ToString("0.0", CultureInfo.InvariantCulture)}%"
        : "—";
}

<div class="container mt-2">
    <h2>Statystyki</h2>

    @if (Model.Data == null)
    {
        <p>Brak danych.</p>
    }
    else
    {
        <!-- 2.1 Header tiles -->
        <div class="row g-3 mt-1">
            @foreach (var tile in Model.Data.Summary.Tiles)
            {
                <partial name="_StatTile" model="tile" />
            }
        </div>

        <!-- 2.9 Streak leaders -->
        <h5 class="mt-4 mb-3">Najdłuższe serie</h5>
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-fire fs-2 text-danger"></i>
                        <div>
                            <div class="fw-semibold">Najdłuższa seria ułożeń</div>
                            @if (Model.Data.StreakLeaders.Solve != null)
                            {
                                <div class="text-muted small">
                                    <a asp-page="/Users/UserProfile" asp-route-id="@Model.Data.StreakLeaders.Solve.UserId">@Model.Data.StreakLeaders.Solve.FullName</a>
                                    — @Model.Data.StreakLeaders.Solve.Length ułożeń
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small">Brak danych.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-md-6">
                <div class="card h-100 border-0 shadow-sm p-3">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-trophy-fill fs-2 text-warning"></i>
                        <div>
                            <div class="fw-semibold">Najdłuższa seria zwycięstw</div>
                            @if (Model.Data.StreakLeaders.Win != null)
                            {
                                <div class="text-muted small">
                                    <a asp-page="/Users/UserProfile" asp-route-id="@Model.Data.StreakLeaders.Win.UserId">@Model.Data.StreakLeaders.Win.FullName</a>
                                    — @Model.Data.StreakLeaders.Win.Length zwycięstw
                                </div>
                            }
                            else
                            {
                                <div class="text-muted small">Brak danych.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Accuracy leaders -->
        <h5 class="mt-4 mb-1">Najlepsza skuteczność</h5>
        <div class="text-muted small mb-2">minimum 10 prób</div>
        @if (Model.Data.AccuracyLeaders.Entries.Count == 0)
        {
            <p class="text-muted">Brak danych.</p>
        }
        else
        {
            var accuracyTotal = Model.Data.AccuracyLeaders.Entries.Count;
            var accuracyHidden = Math.Max(0, accuracyTotal - 5);
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Zawodnik</th>
                            <th class="text-nowrap">Skuteczność</th>
                            <th class="text-nowrap">Próby</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < accuracyTotal; i++)
                        {
                            var entry = Model.Data.AccuracyLeaders.Entries[i];
                            var rowClass = i >= 5 ? "stats-extra-row accuracy-extra" : null;
                            var rowStyle = i >= 5 ? "display: none;" : null;
                            <tr class="@rowClass" style="@rowStyle">
                                <td>@(i + 1)</td>
                                <td>
                                    <a asp-page="/Users/UserProfile" asp-route-id="@entry.UserId">@entry.FullName</a>
                                </td>
                                <td class="fw-bold text-nowrap">@Pct(entry.ValidSolves, entry.Attempts)</td>
                                <td class="text-nowrap">@entry.ValidSolves / @entry.Attempts</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (accuracyHidden > 0)
            {
                <div class="text-end mt-2">
                    <a href="#" class="stats-show-more" data-target="accuracy-extra">Pokaż więcej</a>
                </div>
            }
        }

        <!-- Rolling Ao12 leaders -->
        <h5 class="mt-4 mb-1">Krocząca Ao12</h5>
        <div class="text-muted small mb-2">spośród 12 kolejnych ułożeń z różnych rund</div>
        @if (Model.Data.RollingAo12Leaders.Entries.Count == 0)
        {
            <p class="text-muted">Brak danych.</p>
        }
        else
        {
            var ao12Total = Model.Data.RollingAo12Leaders.Entries.Count;
            var ao12Hidden = Math.Max(0, ao12Total - 5);
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Zawodnik</th>
                            <th class="text-nowrap">Ao12</th>
                            <th class="d-none d-md-table-cell">Wyniki</th>
                            <th class="d-md-none"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < ao12Total; i++)
                        {
                            var entry = Model.Data.RollingAo12Leaders.Entries[i];
                            var window = entry.Window.ToArray();
                            var parts = new List<string>(window.Length);
                            for (int j = 0; j < window.Length; j++)
                            {
                                parts.Add(SolveFormatHelper.FormatWithParens(window, j));
                            }
                            var solvesText = string.Join(", ", parts);
                            var rowClass = i >= 5 ? "stats-extra-row ao12-extra" : null;
                            var rowStyle = i >= 5 ? "display: none;" : null;
                            <tr class="@rowClass" style="@rowStyle">
                                <td>@(i + 1)</td>
                                <td>
                                    <a asp-page="/Users/UserProfile" asp-route-id="@entry.UserId">@entry.FullName</a>
                                </td>
                                <td class="fw-bold text-nowrap">@entry.BestAo12.ToString()</td>
                                <td class="d-none d-md-table-cell">@solvesText</td>
                                <td class="d-md-none text-end">
                                    <button type="button" class="btn btn-link btn-sm p-0"
                                            data-bs-toggle="modal" data-bs-target="#solvesModal"
                                            data-solves="@solvesText" data-player="@entry.FullName"
                                            aria-label="Pokaż ułożenia">
                                        <i class="bi bi-list-ul"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (ao12Hidden > 0)
            {
                <div class="text-end mt-2">
                    <a href="#" class="stats-show-more" data-target="ao12-extra">Pokaż więcej</a>
                </div>
            }
        }

        <!-- Rolling Ao25 leaders -->
        <h5 class="mt-4 mb-1">Krocząca Ao25</h5>
        <div class="text-muted small mb-2">spośród 25 kolejnych ułożeń z różnych rund</div>
        @if (Model.Data.RollingAo25Leaders.Entries.Count == 0)
        {
            <p class="text-muted">Brak danych.</p>
        }
        else
        {
            var ao25Total = Model.Data.RollingAo25Leaders.Entries.Count;
            var ao25Hidden = Math.Max(0, ao25Total - 5);
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Zawodnik</th>
                            <th class="text-nowrap">Ao25</th>
                            <th class="d-none d-md-table-cell">Wyniki</th>
                            <th class="d-md-none"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < ao25Total; i++)
                        {
                            var entry = Model.Data.RollingAo25Leaders.Entries[i];
                            var window = entry.Window.ToArray();
                            var parts = new List<string>(window.Length);
                            for (int j = 0; j < window.Length; j++)
                            {
                                parts.Add(SolveFormatHelper.FormatWithParens(window, j, dropCount: 2));
                            }
                            var solvesText = string.Join(", ", parts);
                            var rowClass = i >= 5 ? "stats-extra-row ao25-extra" : null;
                            var rowStyle = i >= 5 ? "display: none;" : null;
                            <tr class="@rowClass" style="@rowStyle">
                                <td>@(i + 1)</td>
                                <td>
                                    <a asp-page="/Users/UserProfile" asp-route-id="@entry.UserId">@entry.FullName</a>
                                </td>
                                <td class="fw-bold text-nowrap">@entry.BestAo25.ToString()</td>
                                <td class="d-none d-md-table-cell">@solvesText</td>
                                <td class="d-md-none text-end">
                                    <button type="button" class="btn btn-link btn-sm p-0"
                                            data-bs-toggle="modal" data-bs-target="#solvesModal"
                                            data-solves="@solvesText" data-player="@entry.FullName"
                                            aria-label="Pokaż ułożenia">
                                        <i class="bi bi-list-ul"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (ao25Hidden > 0)
            {
                <div class="text-end mt-2">
                    <a href="#" class="stats-show-more" data-target="ao25-extra">Pokaż więcej</a>
                </div>
            }
        }

        <!-- Shared solves modal — populated by both the Ao12 and Ao25 mobile triggers. -->
        <div class="modal fade" id="solvesModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="solvesModalLabel">Ułożenia</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zamknij"></button>
                    </div>
                    <div class="modal-body" id="solvesModalBody"></div>
                </div>
            </div>
        </div>

        <!-- 2.7 Per-season records table -->
        <h5 class="mt-4 mb-3">Statystyki sezonów</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Sezon</th>
                        <th class="text-nowrap">Najlepszy single</th>
                        <th>Zawodnik</th>
                        <th class="text-nowrap">Najlepsza Ao5</th>
                        <th>Zawodnik</th>
                        <th>Zawodników</th>
                        <th>Ułożenia</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Data.SeasonRecords.Count == 0)
                {
                    <tr><td colspan="7" class="text-center">Brak danych.</td></tr>
                }
                else
                {
                    @foreach (var row in Model.Data.SeasonRecords)
                    {
                        <tr>
                            <td>@row.SeasonName</td>
                            <td class="fw-bold text-nowrap">@(row.BestSingle?.ToString() ?? "-")</td>
                            <td>
                                @if (row.BestSingleUserId.HasValue)
                                {
                                    <a asp-page="/Users/UserProfile" asp-route-id="@row.BestSingleUserId">@row.BestSingleUserFullName</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="fw-bold text-nowrap">@(row.BestAverage?.ToString() ?? "-")</td>
                            <td>
                                @if (row.BestAverageUserId.HasValue)
                                {
                                    <a asp-page="/Users/UserProfile" asp-route-id="@row.BestAverageUserId">@row.BestAverageUserFullName</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@row.ParticipantCount</td>
                            <td class="text-nowrap">@row.ValidSolves / @row.Attempts</td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <!-- 2.8 Per-league records and averages table -->
        <h5 class="mt-4 mb-3">Statystyki lig</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Liga</th>
                        <th class="text-nowrap">Średni czas</th>
                        <th class="text-nowrap">Najlepszy single</th>
                        <th>Zawodnik</th>
                        <th class="text-nowrap">Najlepsza Ao5</th>
                        <th>Zawodnik</th>
                    </tr>
                </thead>
                <tbody>
                @if (Model.Data.LeagueRecords.Count == 0)
                {
                    <tr><td colspan="6" class="text-center">Brak danych.</td></tr>
                }
                else
                {
                    @foreach (var row in Model.Data.LeagueRecords)
                    {
                        <tr>
                            <td>@row.LeagueName</td>
                            <td class="text-nowrap">@(row.AverageSolve?.ToString() ?? "-")</td>
                            <td class="fw-bold text-nowrap">@(row.BestSingle?.ToString() ?? "-")</td>
                            <td>
                                @if (row.BestSingleUserId.HasValue)
                                {
                                    <a asp-page="/Users/UserProfile" asp-route-id="@row.BestSingleUserId">@row.BestSingleUserFullName</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td class="fw-bold text-nowrap">@(row.BestAverage?.ToString() ?? "-")</td>
                            <td>
                                @if (row.BestAverageUserId.HasValue)
                                {
                                    <a asp-page="/Users/UserProfile" asp-route-id="@row.BestAverageUserId">@row.BestAverageUserFullName</a>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        <!-- 2.4 Solve duration histogram -->
        <h5 class="mt-4 mb-3">Rozkład czasów ułożeń</h5>
        <div class="card border-0 shadow-sm p-3">
            <canvas id="duration-histogram"
                    data-labels='@Html.Raw(JsonSerializer.Serialize(Model.Data.SolveDurations.Buckets.Select(b => b.Label).ToArray()))'
                    data-values='@Html.Raw(JsonSerializer.Serialize(Model.Data.SolveDurations.Buckets.Select(b => b.Count).ToArray()))'></canvas>
        </div>

        <!-- 2.3 Day-of-week × hour-of-day heatmap -->
        <h5 class="mt-4 mb-3">Rozkład godzinowy wgrywania wyników</h5>
        <div class="card border-0 shadow-sm p-3">
            <div class="table-responsive">
                <table class="table table-bordered table-sm mb-0" style="font-size: 0.75rem; text-align: center;">
                    <thead>
                        <tr>
                            <th></th>
                            @for (int h = 0; h < 24; h++)
                            {
                                <th>@h.ToString("00")</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            <tr>
                                <th>@dayNames[d]</th>
                                @for (int h = 0; h < 24; h++)
                                {
                                    var count = Model.Data.Heatmap.Matrix[d, h];
                                    double alpha = Model.Data.Heatmap.MaxCount > 0
                                        ? (double)count / Model.Data.Heatmap.MaxCount
                                        : 0.0;
                                    string bg;
                                    if (count > 0)
                                    {
                                        double hue = 60 - 60 * alpha;
                                        double lightness = 88 - 40 * alpha;
                                        var hueStr = hue.ToString("0.0", CultureInfo.InvariantCulture);
                                        var lightStr = lightness.ToString("0.0", CultureInfo.InvariantCulture);
                                        bg = $"background-color: hsl({hueStr}, 100%, {lightStr}%);";
                                    }
                                    else
                                    {
                                        bg = string.Empty;
                                    }
                                    <td style="@bg"></td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 2.6 Match score distribution -->
        <h5 class="mt-4 mb-3">Rozkład wyników meczów</h5>
        <div class="card border-0 shadow-sm p-3">
            @{
                var observedBuckets = Model.Data.ScoreDistribution.Buckets.Where(b => b.Count > 0).ToList();
                var observedLabels = observedBuckets.Select(b => b.Label).ToArray();
                var observedValues = observedBuckets.Select(b => b.Count).ToArray();
                var chartHeight = Math.Max(180, observedBuckets.Count * 28);
            }
            <div style="height: @(chartHeight)px;">
                <canvas id="score-distribution"
                        data-labels='@Html.Raw(JsonSerializer.Serialize(observedLabels))'
                        data-values='@Html.Raw(JsonSerializer.Serialize(observedValues))'></canvas>
            </div>
        </div>
    }
</div>

@section HeadScripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
}

@section Scripts {
    <script>
        (function () {
            function renderBar(canvasId) {
                var el = document.getElementById(canvasId);
                if (!el) return;
                var labels = JSON.parse(el.dataset.labels || '[]');
                var values = JSON.parse(el.dataset.values || '[]');
                new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: values,
                            backgroundColor: 'rgba(13,110,253,0.6)',
                            borderColor: 'rgba(13,110,253,1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                    }
                });
            }

            function renderHorizontalBar(canvasId) {
                var el = document.getElementById(canvasId);
                if (!el) return;
                var labels = JSON.parse(el.dataset.labels || '[]');
                var values = JSON.parse(el.dataset.values || '[]');
                new Chart(el, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: values,
                            backgroundColor: 'rgba(13,110,253,0.6)',
                            borderColor: 'rgba(13,110,253,1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        indexAxis: 'y',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
                    }
                });
            }

            renderBar('duration-histogram');
            renderHorizontalBar('score-distribution');

            // Collapsible "show more" links for the accuracy + Ao12 + Ao25 leaderboards.
            var links = document.querySelectorAll('.stats-show-more');
            for (var i = 0; i < links.length; i++) {
                links[i].addEventListener('click', function (ev) {
                    ev.preventDefault();
                    var link = ev.currentTarget;
                    var targetClass = link.getAttribute('data-target');
                    if (!targetClass) return;
                    var rows = document.getElementsByClassName(targetClass);
                    var hidden = rows.length > 0 && rows[0].style.display === 'none';
                    for (var r = 0; r < rows.length; r++) {
                        rows[r].style.display = hidden ? '' : 'none';
                    }
                    link.textContent = hidden ? 'Zwiń' : 'Pokaż więcej';
                });
            }

            // Shared solves modal — copy the data-* payload from the clicked button into the modal body.
            var modalEl = document.getElementById('solvesModal');
            if (modalEl) {
                modalEl.addEventListener('show.bs.modal', function (ev) {
                    var btn = ev.relatedTarget;
                    if (!btn) return;
                    document.getElementById('solvesModalLabel').textContent = btn.getAttribute('data-player') || 'Ułożenia';
                    document.getElementById('solvesModalBody').textContent = btn.getAttribute('data-solves') || '';
                });
            }
        })();
    </script>
}
